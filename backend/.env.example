# Copy to .env and fill in. Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Free model (must support OpenAI-style tool_calls for the agent loop)
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Feed screenshots to the model so it can actually SEE the page (visual design,
# imagery, color). Needs a VISION-capable model above. Leave false for text-only models.
OPENROUTER_VISION=false
# Cheap/fast model for the browser "hands" (Stagehand observe/act). Defaults to a
# free model so only the brain (OPENROUTER_MODEL) runs on the expensive model.
STAGEHAND_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Browserbase — https://www.browserbase.com (free tier). Dashboard → Settings.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

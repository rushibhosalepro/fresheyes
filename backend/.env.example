# ── FreshEyes backend — environment variables ──────────────────────────
# Copy this file to `.env` and fill in the REQUIRED values below.

# ── REQUIRED ───────────────────────────────────────────────────────────
# OpenRouter API key — the LLM "brain". Free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Browserbase — the real cloud browser. Dashboard → Settings:
# https://www.browserbase.com
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── OPTIONAL (defaults shown; uncomment to override) ───────────────────
# Brain model — must support OpenAI-style tool_calls for the agent loop.
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Cheap/fast model for the browser "hands" (Stagehand observe/act).
STAGEHAND_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Feed screenshots to the model so it can SEE the page (visual design, imagery,
# color). Needs a vision-capable OPENROUTER_MODEL; leave false for text-only.
OPENROUTER_VISION=false
# Max agent turns per audit (safety cap). Default 30.
# MAX_STEPS=30
# Port the backend listens on. Default 8787.
# PORT=8787
# Allowed CORS origin for the frontend. Default: any origin.
# FRONTEND_ORIGIN=http://localhost:3000
